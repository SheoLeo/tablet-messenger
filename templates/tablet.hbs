<div class="tablet-layout">
  <aside class="tablet-contacts">
    <header class="tablet-contacts__header">Контакты</header>
    <ul class="tablet-contacts__list">
      {{#each contacts}}
      <li class="tablet-contact {{#if active}}is-active{{/if}}" data-contact-id="{{id}}">
        <div class="tablet-contact__avatar-wrap">
          <span class="tablet-contact__avatar">{{initials}}</span>
          <span class="tablet-contact__presence tablet-contact__presence--{{status}}" aria-hidden="true"></span>
        </div>
        <div class="tablet-contact__content">
          <div class="tablet-contact__top">
            <span class="tablet-contact__name">{{name}}</span>
            <div class="tablet-contact__meta">
              {{#if hasUnread}}
              <span class="tablet-contact__dot" aria-label="Есть непрочитанные сообщения"></span>
              <span class="tablet-contact__unread">{{unreadCount}}</span>
              {{/if}}
              <span class="tablet-contact__time">{{time}}</span>
            </div>
          </div>
          <div class="tablet-contact__bottom">
            <span class="tablet-contact__status tablet-contact__status--{{status}}">{{status}}</span>
            <span class="tablet-contact__preview">{{lastMessage}}</span>
          </div>
        </div>
      </li>
      {{/each}}
    </ul>
  </aside>

  <section class="tablet-chat">
    <header class="tablet-chat__header">
      <div class="tablet-chat__name">{{activeContact.name}}</div>
      <div class="tablet-chat__status">{{activeContact.status}}</div>
    </header>

    <div class="tablet-chat__messages">
      {{#each messages}}
      <article class="tablet-message {{#if mine}}tablet-message--mine{{/if}} {{#if isNpc}}tablet-message--npc{{/if}}">
        <p class="tablet-message__sender">{{sender}}</p>
        <p class="tablet-message__text">{{text}}</p>
        <time class="tablet-message__time">{{time}}</time>
      </article>
      {{/each}}
    </div>

    <footer class="tablet-chat__composer">
      {{#if canSendAsNpc}}
      <select class="tablet-send-as" aria-label="Режим отправки">
        <option value="player">Я</option>
        <option value="npc">От имени NPC</option>
      </select>
      {{/if}}
      <input class="tablet-input" type="text" placeholder="Введите сообщение" />
      <button class="tablet-send" type="button">Отправить</button>
    </footer>
  </section>
</div>
